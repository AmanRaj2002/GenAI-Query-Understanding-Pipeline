version: '3.8'

services:
  redis:
    image: redis/redis-stack-server:latest # Includes vector search capabilities
    ports:
      - "6379:6379"

  mlflow:
    image: ghcr.io/mlflow/mlflow:v2.8.0
    command: mlflow server --host 0.0.0.0 --port 5000
    ports:
      - "5000:5000"

  api:
    build: 
      context:.
      dockerfile: Dockerfile.api # (Requires a basic FastAPI Dockerfile)
    command: uvicorn src.api.main:app --host 0.0.0.0 --port 8000
    ports:
      - "8000:8000"
    environment:
      - REDIS_URL=redis://redis:6379
      - MLFLOW_TRACKING_URI=http://mlflow:5000
    depends_on:
      - redis

  ui:
    build:
      context:.
      dockerfile: Dockerfile.ui # (Requires a basic Streamlit Dockerfile)
    command: streamlit run src/app/ui.py --server.port=8501 --server.address=0.0.0.0
    ports:
      - "8501:8501"
    depends_on:
      - api